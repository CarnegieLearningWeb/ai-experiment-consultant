# Server
PORT=3001
NODE_ENV=development

# Frontend dev server (Vite). Used by server CORS allowlist in dev.
CLIENT_ORIGIN=http://localhost:5173

# Debug logging — prints categorized server-side activity (tool calls, UpGrade
# requests, simulation summary, warnings). Defaults to on when NODE_ENV is not
# "production". Set explicitly to "true" or "false" to override.
DEBUG_LOGGING=true

# Anthropic API (required once chat is wired up in M2)
ANTHROPIC_API_KEY=

# Anthropic model
ANTHROPIC_MODEL=claude-opus-4-7

# UpGrade demo backend (used by simulation feature in M4)
# Base URL — endpoint paths sit under /v6/...
UPGRADE_API_URL=https://upgrade-demo.carnegielearning.com/api

# UpGrade service account key path
UPGRADE_SERVICE_ACCOUNT_KEY_PATH=upgrade-service-account-key.json

# Semantic Scholar API key — optional but **strongly recommended** for the
# Related Research Grounding feature. Unauthenticated requests share a small
# pool with all other anonymous clients and frequently hit HTTP 429 in
# practice, which means paper search will return inconsistent results. With a
# key, the cumulative limit is 1 request per second across endpoints, and the
# tool throttles to stay safely under it.
#
# Request a free key at https://www.semanticscholar.org/product/api#api-key
# and paste it below. Treat unauthenticated mode as best-effort only.
SEMANTIC_SCHOLAR_API_KEY=

# Server
PORT=3001
NODE_ENV=development

# Frontend dev server (Vite). Used by server CORS allowlist in dev.
CLIENT_ORIGIN=http://localhost:5173

# Debug logging — server-side activity. Defaults on outside production.
DEBUG_LOGGING=true

# Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Anthropic model
ANTHROPIC_MODEL=claude-opus-4-8

# UpGrade Base URL
UPGRADE_API_URL=https://upgrade-demo.carnegielearning.com/api

# UpGrade service account key path
UPGRADE_SERVICE_ACCOUNT_KEY_PATH=upgrade-service-account-key.json

# Semantic Scholar API key — Get one free at https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key

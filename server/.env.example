# server/.env.example
#
# This mirrors the root .env.example for clarity. The root .env is the one
# that actually gets loaded (dotenv reads it from the process cwd, which is
# the workspace root when running `npm run dev`).

PORT=3001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

ANTHROPIC_API_KEY=
UPGRADE_API_URL=https://upgrade-demo.carnegielearning.com/api
UPGRADE_SERVICE_ACCOUNT_KEY_PATH=upgrade-service-account-key.json

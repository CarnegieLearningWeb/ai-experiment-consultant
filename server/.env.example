# Debug logging — server-side activity. Set false (or unset) to silence.
DEBUG_LOGGING=true

# Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Anthropic model
ANTHROPIC_MODEL=claude-opus-4-8

# Google login
GOOGLE_CLIENT_ID=your_google_client_id
SESSION_SECRET=your_session_secret

# Local presentation only: replace Google sign-in with a one-click demo session.
# Never enable this in a deployed or production environment.
DEMO_AUTH_BYPASS=false

# UpGrade Base URL
UPGRADE_API_URL=https://upgrade-demo.carnegielearning.com/api

# UpGrade service account key path
UPGRADE_SERVICE_ACCOUNT_KEY_PATH=upgrade-service-account-key.json

# Semantic Scholar API key
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key
